name: "Task 定时任务"
description: "定时签到任务合集，包含龙湖天街、喜马拉雅、高德打车、每日摸鱼、汇率监控、读懂世界、Bilibili、52破解"
author: "kefengyoyo"
icon: "https://raw.githubusercontent.com/Sliverkiss/QuantumultX/main/icon/gril.png"

env_schema:
  LHTJ_CRON:
    name: 龙湖天街任务时间
    description: Cron 表达式，默认每天 09:05
    default_value: "05 9 * * *"
  LHTJ_ENABLE:
    name: 龙湖天街任务开关
    options:
      - "true"
      - "false"
  XMLY_CRON:
    name: 喜马拉雅任务时间
    description: Cron 表达式，默认每天 08:59
    default_value: "59 8 * * *"
  XMLY_ENABLE:
    name: 喜马拉雅任务开关
    options:
      - "true"
      - "false"
  AMP_CRON:
    name: 高德打车任务时间
    description: Cron 表达式，默认每天 09:06
    default_value: "06 9 * * *"
  AMP_ENABLE:
    name: 高德打车任务开关
    options:
      - "true"
      - "false"
  MOYU_CRON:
    name: 每日摸鱼任务时间
    description: Cron 表达式，默认每天 07:55
    default_value: "55 7 * * *"
  MOYU_ENABLE:
    name: 每日摸鱼任务开关
    options:
      - "true"
      - "false"
  HLJK_CRON:
    name: 汇率监控任务时间
    description: Cron 表达式，默认每天 08:10
    default_value: "10 8 * * *"
  HLJK_ENABLE:
    name: 汇率监控任务开关
    options:
      - "true"
      - "false"
  S60S_CRON:
    name: 读懂世界任务时间
    description: Cron 表达式，默认每天 09:15
    default_value: "15 9 * * *"
  S60S_ENABLE:
    name: 读懂世界任务开关
    options:
      - "true"
      - "false"
  BILI_CRON:
    name: Bilibili任务时间
    description: Cron 表达式，默认每天 07:30
    default_value: "30 7 * * *"
  BILI_ENABLE:
    name: Bilibili任务开关
    options:
      - "true"
      - "false"
  POJIE_CRON:
    name: 52破解签到时间
    description: Cron 表达式，默认每天 09:00
    default_value: "0 9 * * *"
  POJIE_ENABLE:
    name: 52破解签到开关
    options:
      - "true"
      - "false"

scriptings:
  - schedule:
      name: 龙湖天街
      cron: "05 9 * * *"
      script_url: "https://raw.githubusercontent.com/leiyiyan/resource/main/script/lhtj/lhtj.js"
      timeout: 300
      disabled: false

  - schedule:
      name: 喜马拉雅
      cron: "59 8 * * *"
      script_url: "https://raw.githubusercontent.com/ClydeTime/Surge/main/Script/Task/xmly.js"
      timeout: 300
      disabled: false

  - schedule:
      name: 高德打车
      cron: "06 9 * * *"
      script_url: "https://raw.githubusercontent.com/wf021325/qx/master/task/ampDache.js"
      timeout: 120
      disabled: false

  - schedule:
      name: 每日摸鱼
      cron: "55 7 * * *"
      script_url: "https://raw.githubusercontent.com/Yuheng0101/X/main/Tasks/moyu.js"
      timeout: 300
      disabled: false

  - schedule:
      name: 汇率监控
      cron: "10 8 * * *"
      script_url: "https://raw.githubusercontent.com/chxm1023/Task/main/hljk.js"
      timeout: 300
      disabled: false

  - schedule:
      name: 读懂世界
      cron: "15 9 * * *"
      script_url: "https://raw.githubusercontent.com/Yuheng0101/X/main/Tasks/60s.js"
      timeout: 300
      disabled: false

  - schedule:
      name: Bilibili
      cron: "30 7 * * *"
      script_url: "https://raw.githubusercontent.com/ClydeTime/BiliBili/refs/heads/main/js/BiliBiliDailyBonus.js"
      timeout: 300
      disabled: false

  - schedule:
      name: 52破解签到
      cron: "0 9 * * *"
      script_url: "https://raw.githubusercontent.com/Yuheng0101/X/main/Tasks/52pojie.js"
      timeout: 300
      disabled: false
